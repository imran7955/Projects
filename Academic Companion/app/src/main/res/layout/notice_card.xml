<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    card_view:cardElevation="4dp"
    card_view:cardCornerRadius="8dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/notice_card_shape"
        android:elevation="6dp"
        android:padding="12dp">

        <!-- Deadline (Top-Left) -->
        <TextView
            android:id="@+id/tvDeadline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#D32F2F"
            android:padding="6dp"
            android:text="24/5/25 10:25 AM"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:layout_alignParentStart="true"/>

        <!-- Issue Date (Top-Right) -->
        <TextView
            android:id="@+id/tvIssueDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="Issued: 20/5/25"
            android:textSize="12sp" />

        <!-- Type and Subject (Below deadline and issue date) -->
        <TextView
            android:id="@+id/tvTypeSubject"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvDeadline"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="8dp"
            android:text="CT: Networking"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Description TextView (initially shows 3 lines with ellipsize) -->
        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvTypeSubject"
            android:layout_marginTop="35dp"
            android:text="Chapters 4-6 will be covered in the test. This is a detailed explanation that will go over the objectives, key topics, and areas of focus. Please make sure to revise all the related exercises and practice questions to be well-prepared for the test."
            android:textSize="14sp"
            android:maxLines="3"
            android:ellipsize="end" />

        <!-- Read More Button -->
        <TextView
            android:id="@+id/tvReadMore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvDescription"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="4dp"
            android:text="More..."
            android:textColor="@android:color/holo_blue_dark"
            android:textSize="12sp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Details Button -->
        <Button
            android:id="@+id/btnEditNotice"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_below="@id/tvReadMore"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="16dp"
            android:padding="1dp"
            android:text="Edit Notice"
            android:textSize="10dp" />

        <Button
            android:id="@+id/btnDeleteNotice"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_below="@id/tvReadMore"
            android:layout_toStartOf="@id/btnEditNotice"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="16dp"
            android:text="Delete"
            android:textSize="10dp"
            android:padding="1dp" />


    </RelativeLayout>
</androidx.cardview.widget.CardView>
